LAB_HOST=127.0.0.1
LAB_API_PORT=8787
LAB_MAX_UPLOAD_MB=25
LAB_DATA_DIR=.data

# Local provider. Ollama is intentionally loopback-only.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_NUM_CTX=8192
OLLAMA_KEEP_ALIVE=30m
AI_TIMEOUT_SECONDS=240

# Safe local parsing boundaries and specialist parsers.
LAB_MAX_PAGES=500
PARSER_TIMEOUT_SECONDS=240
OCR_LANGUAGES=eng
OCR_DPI=170
OCR_PARSE_SCORE_THRESHOLD=0.62
DOCLING_MODE=auto
DOCLING_DEVICE=auto
GROBID_BASE_URL=http://127.0.0.1:8070
GROBID_MODE=auto
FIELD_MAX_ATTEMPTS=2
FIELD_CONTEXT_CHARACTERS=18000
JOB_LEASE_SECONDS=60

# Optional DOI/title reconciliation. If enabled, provide a contact email.
CROSSREF_ENABLED=false
CROSSREF_MAILTO=

# Optional OpenAI-compatible comparison provider. Keep the real key in .env.
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=

# Browser-safe API location. This contains no secret.
NEXT_PUBLIC_LAB_API_URL=http://127.0.0.1:8787
